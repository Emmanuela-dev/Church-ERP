# Local Postgres (default option)
DATABASE_URL=postgresql://postgres:password@localhost:5432/church_db

# Supabase Postgres (recommended for deployment)
# Use either direct connection or transaction pooler URL from Supabase settings.
# If using Supabase, you can set this and leave DATABASE_URL unset.
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@<host>:5432/postgres?sslmode=require

SECRET_KEY=change-me
